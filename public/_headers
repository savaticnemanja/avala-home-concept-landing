# Netlify / Cloudflare Pages cache rules
# Vite hashes all filenames under /assets/ → safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML must revalidate on every request so new deploys are picked up immediately
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# Root (SPA entry point served as index.html)
/
  Cache-Control: no-cache, no-store, must-revalidate

# Static files in /public that are NOT hashed — moderate cache
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap.xml
  Cache-Control: public, max-age=86400
/site.webmanifest
  Cache-Control: public, max-age=86400
/favicon*
  Cache-Control: public, max-age=604800
/*.png
  Cache-Control: public, max-age=604800
/*.ico
  Cache-Control: public, max-age=604800
/apple-touch-icon.png
  Cache-Control: public, max-age=604800
/presentation.pdf
  Cache-Control: public, max-age=604800
